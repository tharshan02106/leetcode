class Solution {
public:
    void nextPermutation(vector<int>& nums) {
        int p1 = ssize(nums) - 2, p2 = ssize(nums) - 1;

        while (p1 >= 0 && nums[p1] >= nums[p1 + 1]) p1--;

        if (p1 >= 0){
            while (nums[p2] <= nums[p1]) p2--;
            swap(nums[p1], nums[p2]);
        }

        reverse(nums.begin() + p1 + 1, nums.end());
    }
};
